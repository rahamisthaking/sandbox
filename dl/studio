<script>
    function hmsToSecondsOnly(str) {
		let p = str.split(':'),
			s = 0, m = 1;

		while (p.length > 0) {
			s += m * parseInt(p.pop(), 10);
			m *= 60;
		}
		return s;
	}

    const durationReadableInt = parseInt(hmsToSecondsOnly("00:46:33"))

    function setFileType(type) {
        document.getElementById('fileType').value = type;

        document.getElementById('audioBtn').disabled = true;
        
        document.getElementById('videoBtn').disabled = true;
        
        onDownload();
    }

    function enableButtons() {
        document.getElementById('audioBtn').disabled = false;
        
        document.getElementById('videoBtn').disabled = false;
        
    }

    function downloadFree() {
        document.getElementById('videoQuality').value = document.getElementById('highestFreeVidQuality').value;
        hideModal('premiumModal');
        onDownload();
    }

    function isPremium() {
        return "False" === "True";
    }

    function validateValues() {
        if (durationReadableInt > 21600) {
            toastr.error('The source video duration cannot exceed six (6) hours.')
            return false;
        } else if (document.getElementById('endTime').getAttribute('aria-invalid') || document.getElementById('startTime').getAttribute('aria-invalid')) {
            toastr.error('Please enter valid start and end times.')
            return false;
        } else if (document.getElementById('filename').getAttribute('aria-invalid')) {
            toastr.error('Filename must be at least one (1) character.')
            return false;
        } else {
            let startInt = parseInt(document.getElementById('formStartTime').value);
            let endInt = parseInt(document.getElementById('formEndTime').value);

            if ((startInt > endInt) || (startInt === endInt && durationReadableInt !== 0)) {
                toastr.error('Please enter a start time that is less than the end time.')
                return false;
            } else if (startInt===endInt && durationReadableInt === 0 && !isPremium()) {
				toastr.error('Processing videos that do not provide a duration is an experimental premium feature. Please subscribe to Dirpy Premium or try a different video source.')
				return false;
			}
            return true;
        }
    }

    function notifyOfEmail() {
        document.getElementById('modalBtn').style.display = '';
        document.getElementById('downLoadModalHeaderText').textContent = "The file you requested is still processing. As a premium subscriber, you will automatically receive an email when your file is ready for download.";
    }

    function waitForDownload(requestId) {
        const maxRetries = 5;
        const retryDelay = 1000;
        let retryCount = 0;
        let isRequestComplete = false;
        let socket = null;
        let reconnectTimeout = null;
        let premEmailInterval;
        if (isPremium()) {
            premEmailInterval = window.setTimeout(function() {
                notifyOfEmail();
            }, 1000 * parseInt("0"));
        }

        function connect() {
            if (socket) {
                socket.onclose = null;
                socket.close();
            }
            socket = new WebSocket("wss://atc.dirpy.com/request");

            socket.onopen = function () {
                retryCount = 0;
                socket.send(JSON.stringify({request_id: requestId}));
            };

            socket.onmessage = function (event) {
                try {
                    let data = JSON.parse(event.data);
                    if (data.request_status === 'COMPLETE' || data.request_status === 'ERROR') {
                        isRequestComplete = true;
                        socket.close();
                        handleResult();
                    }
                } catch (e) {
                    console.error("Invalid message received from websocket", e);
                }
            };

            socket.onclose = function(event) {
                if (isRequestComplete) return;
                if (retryCount < maxRetries) {
                    retryCount++;
                    reconnectTimeout = setTimeout(connect, retryDelay);
                } else {
                    handleError();
                }
            };

            socket.onerror = function(err) {
                console.error("WebSocket Error:", err);
            };
        }

        function handleResult() {
            if (isPremium()) clearTimeout(premEmailInterval);

            let downloadStatusForm = new FormData();
            downloadStatusForm.append("request_id", requestId);
            downloadStatusForm.append("csrf_token", "IjBlOGUxZGIwMTRiN2VhOGVmZDI2YjczY2U2MjEyZWFjYTIyZDk2NWUi.afs93g.FP-SwYgeHj2Oh_s6K3vtLDqrx9I");

            axios({
                url: '/download/status',
                method: 'POST',
                headers: {
                    'Content-Type': 'multipart/form-data',
                    'X-CSRFToken': 'IjBlOGUxZGIwMTRiN2VhOGVmZDI2YjczY2U2MjEyZWFjYTIyZDk2NWUi.afs93g.FP-SwYgeHj2Oh_s6K3vtLDqrx9I'
                },
                data: downloadStatusForm
            }).then(function (response) {
                let status = response.status;

                if (status === 201) {
                    hideModal('downloadModal');
                    let json = response.data;

                    if (json.type === 'error') {
                        toastr.error(json.message);
                        if (json.reload) window.location.href = json.redirect_url;
                    } else if (json.type === 'premium') {
                        document.getElementById('premiumFreeButton').style.display = 'none';
                        document.getElementById('premiumMessageDiv').innerHTML = "<p>" + json.message + "</p>";
                        if (json.is_quality) {
                            
                                document.getElementById('premiumFreeButton').style.display = '';
                            
                        } else {
                            document.getElementById('premiumFreeButton').style.display = 'none';
                        }
                        showModal('premiumModal');
                    } else if (json.type === 'pro') {
                        document.getElementById('proMessageDiv').innerHTML = "<p>" + json.message + "</p>";
                        showModal('proModal');
                    }

                } else if (status === 200) {
                    let fileStatus = response.data.file_status;
                    if (fileStatus === 'COMPLETE') {
                        document.getElementById('requestId').value = requestId;
                        document.getElementById('downloadForm').submit();
                        document.getElementById('requestId').value = '';
                        document.getElementById('modalBtn').style.display = '';
                        document.getElementById('downLoadModalHeaderText').textContent = "Your file is now available. Thank you for using Dirpy!";
                        document.getElementById('progressSpinner').style.display = 'none';
                        document.getElementById('downloadModal').addEventListener('hidden.bs.modal', function (e) {
                            document.getElementById('downLoadModalHeaderText').textContent = "Your download is being processed and will begin shortly. Please be patient!";
                        }, {once: true});
                    }
                }
                enableButtons();
            }).catch(function (error) {
                handleError();
            });
        }

        function handleError() {
            toastr.error('Sorry, something went wrong. Please retry your request or contact us if the problem persists.');
            hideModal('downloadModal');
            enableButtons();
            if (isPremium()) clearTimeout(premEmailInterval);
        }
        connect();
    }

    function onDownload() {
        document.getElementById('formStartTime').value = hmsToSecondsOnly(document.getElementById('startTime').value);
        document.getElementById('formEndTime').value = hmsToSecondsOnly(document.getElementById('endTime').value);
        document.getElementById('requestId').value = "";
        if (validateValues()) {
            if (document.getElementById('requestId').value !== "") {
                return true;
            }
            document.getElementById('outputFileName').value = document.getElementById('filename').value;
            document.getElementById('formTitle').value = document.getElementById('title').value;
            document.getElementById('formArtist').value = document.getElementById('artist').value;
            document.getElementById('formComment').value = document.getElementById('comment').value;
            document.getElementById('formGenre').value = document.getElementById('genre').value;
            document.getElementById('formAlbum').value = document.getElementById('album').value;
            document.getElementById('formYear').value = document.getElementById('year').value;
            document.getElementById('formTrack').value = document.getElementById('track').value;
            document.getElementById('subtitles').value = document.getElementById('subtitles_checkbox')?.checked ?? false;

            const downloadForm = document.getElementById('downloadForm');
            const downloadFormData = new FormData(downloadForm);

            axios({
                url: '/studio',
                method: 'POST',
                headers: {
                    'Content-Type': 'multipart/form-data',
                    'X-CSRFToken': 'IjBlOGUxZGIwMTRiN2VhOGVmZDI2YjczY2U2MjEyZWFjYTIyZDk2NWUi.afs93g.FP-SwYgeHj2Oh_s6K3vtLDqrx9I'
                },
                data: downloadFormData
            }).then(function (response) {
                const status = response.status;
                if (status === 201) {
                    const json = response.data;
                    if (json.type === 'error') {
                        toastr.error(json.message);
                        if (json.reload) {
                            window.location.href = json.redirect_url;
                        }
                        hideModal('downloadModal');
                        enableButtons();
                    } else if (json.type === 'premium') {
                        document.getElementById('premiumMessageDiv').innerHTML = "<p>" + json.message + "</p>";
                        document.getElementById('premiumFreeButton').style.display = 'none';
                        if (json.is_quality) {
                            
                                document.getElementById('premiumFreeButton').style.display = '';
                            
                        } else {
                            document.getElementById('premiumFreeButton').style.display = 'none';
                        }
                        hideModal('downloadModal');
                        showModal('premiumModal');
                        enableButtons();
                    } else if (json.type === 'pro') {
                        document.getElementById('proMessageDiv').innerHTML = "<p>" + json.message + "</p>";
                        hideModal('downloadModal');
                        showModal('proModal');
                        enableButtons();
                    }
                } else if (status === 200) {
                    let requestId = response.data.request_id;
                    document.getElementById('modalBtn').style.display = 'none';
                    document.getElementById('progressSpinner').style.display = '';
                    showModal('downloadModal');
                    enableButtons();
                    waitForDownload(requestId);
                } else {
                    enableButtons();
                    return response;
                }
                document.getElementById('requestId').value = "";
            }).catch(function (error) {
                toastr.error('Sorry, something went wrong. Please retry your request or contact us if the problem persists.');
                enableButtons();
                hideModal('downloadModal');
                document.getElementById('requestId').value = "";
            })
            return false;
        } else {
            enableButtons();
            return false;
        }
    }

    function shouldBeValidated(field) {
        return (
            !(field.getAttribute("readonly") || field.readonly) &&
            !(field.getAttribute("disabled") || field.disabled) &&
            (field.getAttribute("pattern") || field.getAttribute("required") || field.getAttribute("premium"))
        );
    }

    function instantValidation(field) {

        let invalid = (
            (field.getAttribute("required") && !field.value)
            || (field.getAttribute("pattern") && field.value && !new RegExp(field.getAttribute("pattern")).test(field.value))
        );

        if (!invalid) {
            let seconds;
            if (field.id === "endTime") {
                seconds = parseInt(hmsToSecondsOnly(field.value));
                if (seconds < 0 || seconds > durationReadableInt || (seconds === 0 && durationReadableInt > 0)) {
                    invalid = true;
                }
            } else if (field.id === "startTime") {
                seconds = hmsToSecondsOnly(field.value);
                if (seconds < 0 || seconds > durationReadableInt || (seconds === durationReadableInt && durationReadableInt > 0)) {
                    invalid = true;
                }
            }
        }

        let nonPremium = false;

        if (!nonPremium && field.getAttribute("aria-warning")) {
            field.removeAttribute("aria-warning");
        } else if (nonPremium) {
            field.setAttribute("aria-warning", "true");
        }

        if (!invalid && field.getAttribute("aria-invalid")) {
            field.removeAttribute("aria-invalid");
        } else if (invalid && !field.getAttribute("aria-invalid")) {
            field.setAttribute("aria-invalid", "true");
        }

    }

    function addEvent(node, type, callback) {
        if (node.addEventListener) {
            node.addEventListener(type, function(e) {
                callback(e, e.target);
            }, false);
        } else if (node.attachEvent) {
            node.attachEvent('on' + type, function(e) {
                callback(e, e.srcElement);
            });
        }
    }

    addEvent(document, "change", function(e, target) {
        if (shouldBeValidated(target)) {
            instantValidation(target);
        }
    });

    document.addEventListener("DOMContentLoaded", function() {
        var video = document.getElementById("media-player");
        var source = document.getElementById("media-source");
        var thumbnail = document.getElementById("fallback-thumbnail");
